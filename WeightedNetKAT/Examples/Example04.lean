 [],
 [(![0, 0], ![0, 1], {(rРЎА, Ріц)}),
  (![0, 0], ![1, 0], {(lРЎА, Ріц)}),
  (![0, 1], ![0, 1], {(rРЎА, Ріц)}),
  (![0, 1], ![1, 0], {(lРЎА, Ріц)}),
  (![1, 0], ![0, 1], {(rРЎА, Ріц)}),
  (![1, 0], ![1, 0], {(lРЎА, Ріц)}),
  (![1, 1], ![0, 1], {(rРЎА, Ріц)}),
