#guard_msgs in
#wnka_eval[Fin 2, Fin 2, Bottleneck РёЋРѕъ] { @mod ~pk[0 Рєд 1] РеЂ @mod ~pk[1 Рєд 1] }

/--
info: ({(llРЎА, Ріц), (lrРЎА, Ріц)},
 [(![0, 0], ![0, 0], {((rlРЎА, rlРЎБ), Ріц)}),
  (![0, 0], ![0, 1], {((lrРЎА, rlРЎБ), Ріц)}),
  (![0, 0], ![1, 0], {((llРЎА, rlРЎБ), Ріц)}),
  (![0, 1], ![0, 1], {((lrРЎА, rlРЎБ), Ріц), ((rlРЎА, rlРЎБ), Ріц)}),
  (![0, 1], ![1, 0], {((llРЎА, rlРЎБ), Ріц)}),
  (![1, 0], ![0, 1], {((lrРЎА, rlРЎБ), Ріц)}),
  (![1, 0], ![1, 0], {((llРЎА, rlРЎБ), Ріц), ((rlРЎА, rlРЎБ), Ріц)}),
  (![1, 1], ![0, 1], {((lrРЎА, rlРЎБ), Ріц)}),
  (![1, 1], ![1, 0], {((llРЎА, rlРЎБ), Ріц)}),
  (![1, 1], ![1, 1], {((rlРЎА, rlРЎБ), Ріц)})],
 [(![1, 0], ![1, 0], {(rlРЎБ, Ріц), (rrРЎА, Ріц)})])
-/
#guard_msgs in
#wnka_eval[Fin 2, Fin 2, Bottleneck РёЋРѕъ] {
  (@mod ~pk[0 Рєд 1] РеЂ @mod ~pk[1 Рєд 1]) ; dup ; @test ~pk[0 Рєд 1]
}

